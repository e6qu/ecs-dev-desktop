# sshd configuration for the golden workspace image.
# Certificate-only auth: the image trusts the control-plane SSH CA public key
# injected at runtime as /etc/ssh/workspace-ca.pub. The workspace ID maps to an
# OpenSSH certificate principal in /etc/ssh/principals/workspace.

Port 22
AddressFamily any
ListenAddress 0.0.0.0

HostKey /etc/ssh/ssh_host_ed25519_key

PermitRootLogin no
PasswordAuthentication no
ChallengeResponseAuthentication no
PubkeyAuthentication yes

TrustedUserCAKeys /etc/ssh/workspace-ca.pub
AuthorizedPrincipalsFile /etc/ssh/principals/%u

AllowUsers workspace
X11Forwarding no
AllowAgentForwarding no
PrintMotd no
PrintLastLog no

# PATH for the `ssh <host> '<cmd>'` exec channel: that runs a NON-login,
# NON-interactive shell, which sources neither /etc/profile (toolchain) nor
# ~/.bashrc, so it would otherwise get only sshd's bare default PATH. Set the full
# PATH here so SSH-exec sees user-installed CLIs (npm global + ~/.local/bin) AND
# the baked toolchain — matching what the integrated terminal/login shell get.
# (Home is fixed at /home/workspace, so a literal path is correct.)
SetEnv PATH=/home/workspace/.npm-global/bin:/home/workspace/.local/bin:/usr/local/go/bin:/home/workspace/go/bin:/opt/rust/cargo/bin:/opt/gradle/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
