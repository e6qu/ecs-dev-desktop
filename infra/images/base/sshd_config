# sshd configuration for the golden workspace image (dual-trust SSH path).
# Registered-key auth: AuthorizedKeysCommand asks the control plane whether the
# presented key is registered to this workspace's owner (authenticated by the
# per-workspace agent token). No standing key trust — the decision is made per
# connection and is revocable by removing the key.

# Per-image drop-ins live here so variants can override them — notably the
# `SetEnv PATH` for the `ssh <host> '<cmd>'` exec channel (a non-login,
# non-interactive shell that sources neither /etc/profile nor ~/.bashrc, so it
# needs PATH set here). Base ships the user-CLI PATH; variants overwrite the
# drop-in with a toolchain-inclusive PATH. Included early so a drop-in's value wins.
Include /etc/ssh/sshd_config.d/*.conf

Port 22
AddressFamily any
ListenAddress 0.0.0.0

HostKey /etc/ssh/ssh_host_ed25519_key

PermitRootLogin no
PasswordAuthentication no
ChallengeResponseAuthentication no
PubkeyAuthentication yes

# Authorize the presented key against the control plane (per-workspace agent
# token, read from /run/edd-ssh-env). Runs as root pre-auth; the script + that
# env file are root-only so the workspace user can't read the agent token.
AuthorizedKeysCommand /usr/local/bin/edd-authorized-keys %t %k
AuthorizedKeysCommandUser root

AllowUsers workspace
X11Forwarding no
AllowAgentForwarding no
PrintMotd no
PrintLastLog no
