# Copy to terraform.tfvars and edit. The auth secret ARNs must already exist in
# Secrets Manager (see the module README "Prerequisites").

region             = "us-east-1"
environment        = "dev"
availability_zones = ["us-east-1a", "us-east-1b"]

# For a real deployment with TLS + workspace routing:
# domain_name     = "dev.example.com"
# route53_zone_id = "Z0123456789ABCDEFGHIJ"

# All secret env vars → their Secrets Manager ARNs (create the secrets first).
# auth_secret_arns = {
#   AUTH_SECRET        = "arn:aws:secretsmanager:us-east-1:111122223333:secret:edd/auth-secret-AbCdEf"
#   AUTH_GITHUB_ID     = "arn:aws:secretsmanager:us-east-1:111122223333:secret:edd/github-id-AbCdEf"
#   AUTH_GITHUB_SECRET = "arn:aws:secretsmanager:us-east-1:111122223333:secret:edd/github-secret-AbCdEf"
#   EDD_TOKEN_ENC_KEY  = "arn:aws:secretsmanager:us-east-1:111122223333:secret:edd/token-enc-key-AbCdEf"
#   EDD_GATEWAY_SECRET = "arn:aws:secretsmanager:us-east-1:111122223333:secret:edd/gateway-secret-AbCdEf"
#   EDD_AGENT_SECRET   = "arn:aws:secretsmanager:us-east-1:111122223333:secret:edd/agent-secret-AbCdEf"
#   EDD_CONNECTION_SECRET = "arn:aws:secretsmanager:us-east-1:111122223333:secret:edd/connection-secret-AbCdEf"
# }

# Non-secret config. EDD_ADMIN_GROUPS is REQUIRED — without it no one is an admin.
# extra_environment = {
#   EDD_ADMIN_GROUPS          = "platform-admins"
#   EDD_MEMBER_GROUPS         = "engineering"
#   AUTH_TRUST_HOST           = "true"
#   EDD_SSH_BASE_DOMAIN       = "ssh.dev.example.com"
# }
