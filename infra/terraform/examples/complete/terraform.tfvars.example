# SPDX-License-Identifier: AGPL-3.0-or-later
# Copy to terraform.tfvars and edit. The auth secret ARNs must already exist in
# Secrets Manager (see docs/deploying.md, or scripts/bootstrap-secrets.sh).

region             = "us-east-1"
environment        = "dev"
availability_zones = ["us-east-1a", "us-east-1b"]

# Private-subnet egress: "instance" (fck-nat, cheap, default) or "gateway" (AWS-managed,
# HA, pricier). Explicit — intentionally NOT derived from `environment`'s name.
# nat_mode = "instance"

# Image production: "local" (default; terraform builds/pushes during apply — needs
# docker + the source checkout), "codebuild" (needs codebuild_source_repo), or
# "pre-published" (images already in ECR).
# image_build_mode = "local"

# Golden base-image variants to build/publish (must match infra/images/ folder names).
# golden_image_repos = ["omnibus"]

# Optional AWS Budgets cost guardrail + alarm notifications (both disabled by default).
# monthly_budget_usd   = 100
# alarm_sns_topic_arns = ["arn:aws:sns:us-east-1:111122223333:edd-alerts"]

# For a real deployment with TLS + workspace routing (the editor is path-based at
# app.<domain>/w/<id>/ — no wildcard DNS/TLS):
# domain_name     = "dev.example.com"
# route53_zone_id = "Z0123456789ABCDEFGHIJ"

# Public SSH front door (independent of the editor domain above). When enabled, also
# build + push a PINNED gateway image tag to the module's ssh_gateway_repository_url
# output and pass it here (the module forbids a mutable :latest for the gateway):
# ssh_base_domain     = "ssh.dev.example.com"
# route53_ssh_zone_id = "Z0123456789ABCDEFGHIJ"
# ssh_gateway_image   = "111122223333.dkr.ecr.us-east-1.amazonaws.com/edd-dev/ssh-gateway:0123456789ab"

# All secret env vars → their Secrets Manager ARNs (create the secrets first).
# auth_secret_arns = {
#   AUTH_SECRET           = "arn:aws:secretsmanager:us-east-1:111122223333:secret:edd/auth-secret-AbCdEf"
#   AUTH_GITHUB_ID        = "arn:aws:secretsmanager:us-east-1:111122223333:secret:edd/github-id-AbCdEf"
#   AUTH_GITHUB_SECRET    = "arn:aws:secretsmanager:us-east-1:111122223333:secret:edd/github-secret-AbCdEf"
#   EDD_TOKEN_ENC_KEY     = "arn:aws:secretsmanager:us-east-1:111122223333:secret:edd/token-enc-key-AbCdEf"
#   EDD_GATEWAY_SECRET    = "arn:aws:secretsmanager:us-east-1:111122223333:secret:edd/gateway-secret-AbCdEf"
#   EDD_AGENT_SECRET      = "arn:aws:secretsmanager:us-east-1:111122223333:secret:edd/agent-secret-AbCdEf"
#   EDD_CONNECTION_SECRET = "arn:aws:secretsmanager:us-east-1:111122223333:secret:edd/connection-secret-AbCdEf"
#   EDD_IMAGE_SOURCE_WEBHOOK_SECRET = "arn:aws:secretsmanager:us-east-1:111122223333:secret:edd/image-webhook-AbCdEf"
# }

# Non-secret config. EDD_ADMIN_GROUPS is REQUIRED — without it no one is an admin.
# extra_environment = {
#   EDD_ADMIN_GROUPS        = "platform-admins"
#   EDD_DEVELOPER_GROUPS    = "engineering"
#   AUTH_TRUST_HOST         = "true"
#   EDD_IMAGE_SOURCE_REPO   = "e6qu/ecs-dev-desktop"
#   EDD_IMAGE_SOURCE_BRANCH = "main"
#   EDD_AWS_PRICING         = "1"
#   EDD_PUBLIC_APP_URL      = "https://app.dev.example.com"
#   EDD_EMAIL_FROM          = "EDD <noreply@dev.example.com>"
#   # Region-accurate rate for the derived per-workspace cost estimate. The config defaults
#   # are us-east-1; only EBS gp3 differs by region (e.g. eu-west-1 = 0.088 vs 0.080/GB-mo,
#   # verified via the Price List API). Fargate + snapshot match across regions. The
#   # authoritative bill comes from Cost Explorer (whole-account on-demand), so this only
#   # tunes the "attributable workspace cost" estimate.
#   EDD_PRICE_EBS_GB_MONTH  = "0.088"
#   # Whole-account cost is the default. Set to "1" only for a SHARED account, and only after
#   # activating the edd:cost-scope cost-allocation tag in AWS Billing (see DO_NEXT).
#   EDD_COST_SCOPE_ENABLED  = "0"
# }
