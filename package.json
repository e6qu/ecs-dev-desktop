{
  "name": "ecs-dev-desktop",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "sh scripts/dev.sh",
    "reap": "sh scripts/reap-local.sh",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:integ": "turbo run test:integ",
    "test:integ:local": "sh scripts/test-integ.sh",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:local": "sh scripts/test-e2e.sh",
    "check-deps": "bash scripts/check-latest-deps.sh",
    "dead-code": "knip --no-config-hints",
    "cpd": "jscpd apps packages services"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "jscpd": "^5.0.10",
    "knip": "^6.17.1",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
