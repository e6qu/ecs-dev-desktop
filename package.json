{
  "name": "ecs-dev-desktop",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "sh scripts/dev.sh",
    "reap": "sh scripts/reap-local.sh",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:integ": "turbo run test:integ",
    "test:integ:local": "sh scripts/test-integ.sh",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:local": "sh scripts/test-e2e.sh",
    "check-deps": "bash scripts/check-latest-deps.sh",
    "check-deps:node": "node scripts/check-node-deps.mjs",
    "dead-code": "knip --no-config-hints",
    "cpd": "jscpd --no-tips apps packages services",
    "test:fuzz": "echo \"For deep fuzzing, edit fuzz-setup.ts interruptAfterTimeLimit to 60000 and run: pnpm turbo run test --force\" && exit 0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "jscpd": "^5.0.12",
    "knip": "^6.26.0",
    "turbo": "^2.10.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
