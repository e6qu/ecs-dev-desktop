# SPDX-License-Identifier: AGPL-3.0-or-later
# Auth.js (NextAuth v5) — see https://authjs.dev. Copy to .env.local and fill in.

AUTH_SECRET=                       # openssl rand -base64 33

# GitHub OAuth app (Settings → Developer settings → OAuth Apps).
# The app is requested with the `read:org` scope so team membership (→ roles via
# EDD_ADMIN_GROUPS/EDD_DEVELOPER_GROUPS as `org/team`) can be read at sign-in.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Override the GitHub REST base (GitHub Enterprise, or the bleephub sim's /api/v3).
# AUTH_GITHUB_API_URL=https://api.github.com

# Azure Entra ID app registration
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=    # https://login.microsoftonline.com/<tenant>/v2.0

# Shauth OpenID Connect. All three coordinates are required before the Shauth
# sign-in button is offered. The callback is https://<EDD host>/api/auth/callback/shauth.
AUTH_SHAUTH_ISSUER=https://auth.dev.e6qu.dev
AUTH_SHAUTH_ID=
AUTH_SHAUTH_SECRET=
# This exact EDD-origin bridge must also be registered on the Shauth client.
# It returns to Shauth's one-time completion endpoint; Shauth then returns the
# browser to EDD's configured `/signed-out` page.
AUTH_SHAUTH_POST_LOGOUT_URL=https://app.edd.dev.e6qu.dev/auth/shauth/logout/complete

# IdP group ids/slugs → role mapping (comma-separated)
EDD_ADMIN_GROUPS=
EDD_DEVELOPER_GROUPS=

# CI-published golden image catalog convergence. The app observes main through
# signed GitHub webhooks and the GitHub commit API, then rolls catalog entries
# only after ECR contains the expected short-SHA tag.
EDD_IMAGE_SOURCE_REPO=e6qu/ecs-dev-desktop
EDD_IMAGE_SOURCE_BRANCH=main
EDD_IMAGE_SOURCE_WEBHOOK_SECRET=
EDD_GOLDEN=omnibus

# DynamoDB (control plane state)
DYNAMODB_TABLE=ecs-dev-desktop
# DYNAMODB_ENDPOINT defaults to the sim at http://127.0.0.1:4566 (brought up by `pnpm dev`).

# Dev-only: honour x-edd-user-id / x-edd-role headers instead of a session.
# NEVER set in production.
# EDD_DEV_AUTH=1

# ── Deployment secrets (NOT needed for `pnpm dev`; required for a real deploy) ──
# Encrypts the user's git token at rest (AES-256-GCM). 32-byte hex: `openssl rand -hex 32`.
# EDD_TOKEN_ENC_KEY=
# HMAC secrets for control-plane ↔ ssh-gateway and ↔ idle-agent machine auth (hex).
# EDD_GATEWAY_SECRET=
# EDD_AGENT_SECRET=
# HMAC for the per-workspace OpenVSCode connection token (the editor-proxy handoff) (hex).
# EDD_CONNECTION_SECRET=
# Auth.js deployment URL + host trust (when running behind a proxy / load balancer).
# Required when Shauth is configured; it fixes the callback origin used above.
# AUTH_URL=https://app.example.com
# AUTH_TRUST_HOST=true
# Invitation email. Missing SES config fails the admin invitation action loudly.
# EDD_PUBLIC_APP_URL=https://app.example.com
# EDD_EMAIL_FROM="EDD <noreply@example.com>"
# Cost rates. Set EDD_AWS_PRICING=1 in AWS to require live AWS Price List rates;
# otherwise declare EDD_PRICE_* rates explicitly if the defaults do not match.
# EDD_AWS_PRICING=1
# EDD_PRICE_FARGATE_VCPU_HOUR=
# EDD_PRICE_FARGATE_GB_HOUR=
# EDD_PRICE_EBS_GB_MONTH=
# EDD_PRICE_SNAPSHOT_GB_MONTH=
# Base domain for a workspace's SSH command (surfaced only when set; needs SSH ingress + DNS).
# EDD_SSH_BASE_DOMAIN=ssh.example.com
