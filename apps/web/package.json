{
  "name": "@edd/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "next build",
    "start": "NODE_ENV=production tsx server.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integ": "vitest run --config vitest.integ.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:pw": "node scripts/run-playwright.mjs",
    "test:pw:live": "node scripts/run-playwright.mjs --config playwright.live.config.ts",
    "test:pw:live:provision": "tsx e2e/live-cloud-setup.ts",
    "test:pw:vscode": "node scripts/run-playwright.mjs --config playwright.vscode.config.ts",
    "screenshot": "tsx scripts/screenshot-ui.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1090.0",
    "@aws-sdk/client-codebuild": "^3.1090.0",
    "@aws-sdk/client-cost-explorer": "^3.1090.0",
    "@aws-sdk/client-ecr": "^3.1090.0",
    "@aws-sdk/client-pricing": "^3.1090.0",
    "@aws-sdk/client-sesv2": "^3.1090.0",
    "@aws-sdk/client-wafv2": "^3.1090.0",
    "@edd/api-client": "workspace:*",
    "@edd/api-contracts": "workspace:*",
    "@edd/auth": "workspace:*",
    "@edd/authz": "workspace:*",
    "@edd/cloudtrail-audit": "workspace:*",
    "@edd/cloudwatch-logs": "workspace:*",
    "@edd/cloudwatch-metrics": "workspace:*",
    "@edd/compute-ecs": "workspace:*",
    "@edd/config": "workspace:*",
    "@edd/control-plane": "workspace:*",
    "@edd/core": "workspace:*",
    "@edd/db": "workspace:*",
    "@edd/iam-preflight": "workspace:*",
    "@edd/storage-ec2": "workspace:*",
    "@xterm/xterm": "^6.0.0",
    "jose": "^6.2.3",
    "next": "^16.2.10",
    "next-auth": "5.0.0-beta.31",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudtrail": "^3.1090.0",
    "@aws-sdk/client-dynamodb": "^3.1090.0",
    "@aws-sdk/client-ec2": "^3.1090.0",
    "@aws-sdk/client-ecs": "^3.1090.0",
    "@edd/e2e": "workspace:*",
    "@edd/editor-monaco": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "fast-check": "^4.9.0",
    "tsx": "^4.23.1"
  }
}
