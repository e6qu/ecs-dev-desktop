{
  "name": "@edd/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integ": "vitest run --config vitest.integ.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:pw": "playwright test",
    "test:pw:live": "playwright test --config playwright.live.config.ts",
    "test:pw:live:provision": "tsx e2e/live-cloud-setup.ts",
    "test:pw:pomerium": "playwright test --config playwright.pomerium.config.ts",
    "test:pw:gate": "playwright test --config playwright.gate.config.ts",
    "test:pw:vscode": "playwright test --config playwright.vscode.config.ts"
  },
  "dependencies": {
    "@edd/api-client": "workspace:*",
    "@edd/api-contracts": "workspace:*",
    "@edd/auth": "workspace:*",
    "@edd/authz": "workspace:*",
    "@edd/cloudtrail-audit": "workspace:*",
    "@edd/cloudwatch-logs": "workspace:*",
    "@edd/cloudwatch-metrics": "workspace:*",
    "@edd/compute-ecs": "workspace:*",
    "@edd/config": "workspace:*",
    "@edd/control-plane": "workspace:*",
    "@edd/core": "workspace:*",
    "@edd/db": "workspace:*",
    "@edd/storage-ec2": "workspace:*",
    "jose": "^6.2.3",
    "next": "^16.2.9",
    "next-auth": "5.0.0-beta.31",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1068.0",
    "@aws-sdk/client-dynamodb": "^3.1068.0",
    "@aws-sdk/client-ec2": "^3.1068.0",
    "@aws-sdk/client-pricing": "^3.1068.0",
    "@aws-sdk/client-ecs": "^3.1068.0",
    "@edd/e2e": "workspace:*",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "tsx": "^4.22.4"
  }
