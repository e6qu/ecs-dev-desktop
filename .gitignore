# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
.next/
out/
*.tsbuildinfo

# Turbo
.turbo/

# Test / coverage
coverage/
playwright-report/
test-results/
.playwright/

# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
*.tfvars
!example.tfvars
# .terraform.lock.hcl is committed on purpose for root configs (provider pinning
# + check-deps gate); reusable modules + examples must NOT pin, so ignore theirs.
infra/terraform/modules/**/.terraform.lock.hcl
infra/terraform/examples/**/.terraform.lock.hcl

# Env / secrets
.env
.env.*
!.env.example

# OS / editor
.DS_Store
*.log

# Local scratch (screenshots, manual artifacts) — never committed
temp/

# VS Code workspace proof outputs (screenshots + Playwright traces)
apps/web/e2e/vscode-shots/
apps/web/playwright-vscode-output/
