{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "test:integ": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": ["DYNAMODB_ENDPOINT", "AWS_REGION"]
    }
  }
}
