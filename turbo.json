{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@edd/reconciler#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@edd/wake-listener#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@edd/web#build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "test:integ": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": ["DYNAMODB_ENDPOINT", "AWS_REGION"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": [
        "AWS_ENDPOINT_URL",
        "AWS_REGION",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AUTH_GITHUB_API_URL",
        "EDD_GITHUB_APP_ID",
        "EDD_GITHUB_APP_KEY",
        "EDD_GITHUB_TEST_ORG",
        "EDD_GITHUB_TEST_REPO",
        "WORKSPACE_IMAGE",
        "RECONCILER_IMAGE",
        "PROXY_IMAGE",
        "NODE_IMAGE"
      ]
    }
  }
}
