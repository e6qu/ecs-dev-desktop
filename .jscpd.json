{
  "$schema": "https://raw.githubusercontent.com/kucherenko/jscpd/master/packages/jscpd/schema.json",
  "threshold": 1,
  "minTokens": 50,
  "reporters": ["console"],
  "absolute": true,
  "format": ["typescript", "tsx", "javascript", "jsx"],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.next/**",
    "**/coverage/**",
    "third_party/**",
    "temp/**",
    "**/*.config.{js,mjs,cjs,ts}",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.integ.ts",
    "**/*.fuzz.test.ts",
    "**/e2e/**",
    "**/*.pw.ts",
    "**/*.pwlive.ts",
    "**/test-support/**"
  ]
}
