{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["third_party/**"],
  "ignoreBinaries": ["ssh-keygen"],
  "workspaces": {
    "apps/web": {
      "entry": [
        "e2e/**/*.pw.ts",
        "e2e/**/*.pwlive.ts",
        "e2e/**/*.pwpom.ts",
        "e2e/live-cloud-setup.ts",
        "**/*.test.ts",
        "**/*.integ.ts"
      ]
    },
    "packages/*": {
      "entry": ["**/*.test.ts", "**/*.integ.ts"]
    },
    "packages/e2e": {
      "entry": ["**/*.e2e.ts"]
    },
    "services/*": {
      "entry": ["**/*.test.ts", "**/*.integ.ts", "**/*.e2e.ts"]
    },
    "services/reconciler": {
      "entry": ["src/run.ts", "**/*.test.ts", "**/*.integ.ts"]
    }
  }
}
