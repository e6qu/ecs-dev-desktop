{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["third_party/**", "infra/images/base/edd-ui-extension/**"],
  "ignoreBinaries": ["ssh-keygen"],
  "workspaces": {
    "apps/demo": {
      "entry": [
        "src/main.tsx",
        "src/lib/node-shims/*.ts",
        "**/*.test.ts",
        "playwright.config.ts",
        "e2e/**/*.spec.ts"
      ]
    },
    "services/editor-monaco": {
      "entry": [
        "src/run.ts",
        "src/index.ts",
        "src/spa/main.ts",
        "vite.config.ts",
        "vitest.config.ts",
        "**/*.test.ts"
      ]
    },
    "apps/web": {
      "entry": [
        "e2e/**/*.pw.ts",
        "e2e/**/*.pwlive.ts",
        "e2e/**/*.pwpom.ts",
        "e2e/**/*.pwgate.ts",
        "e2e/gate-global-setup.ts",
        "e2e/live-cloud-setup.ts",
        "scripts/dev-bootstrap.ts",
        "scripts/screenshot-ui.ts",
        "**/*.test.ts",
        "**/*.integ.ts"
      ]
    },
    "packages/*": {
      "entry": ["**/*.test.ts", "**/*.integ.ts"]
    },
    "packages/e2e": {
      "entry": ["**/*.e2e.ts", "**/*.integ.ts", "src/live-sim-run.ts", "src/aws-ebs-smoke.ts"]
    },
    "services/*": {
      "entry": ["**/*.test.ts", "**/*.integ.ts", "**/*.e2e.ts"]
    },
    "services/reconciler": {
      "entry": ["src/run.ts", "**/*.test.ts", "**/*.integ.ts"]
    }
  }
}
