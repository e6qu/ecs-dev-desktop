# sshd configuration for the workspace SSH node (e2e harness; mirrors the golden
# image's dual-trust auth). Registered-key auth: AuthorizedKeysCommand asks the
# control plane whether the presented key is registered to this workspace's owner
# (authenticated by the per-workspace agent token). No standing key trust.

Port 22
AddressFamily any
ListenAddress 0.0.0.0

HostKey /etc/ssh/ssh_host_ed25519_key

PasswordAuthentication no
ChallengeResponseAuthentication no
PubkeyAuthentication yes

# Authorize the presented key against the control plane (agent token, read from
# the root-only /run/edd-ssh-env). Runs as root pre-auth.
AuthorizedKeysCommand /usr/local/bin/edd-authorized-keys %t %k
AuthorizedKeysCommandUser root

AllowUsers workspace

# Disable features not needed in the workspace model.
X11Forwarding no
AllowAgentForwarding no
PrintMotd no
PrintLastLog no
