# SPDX-License-Identifier: AGPL-3.0-or-later
# Workspace SSH node (e2e harness): standard OpenSSH sshd with dual-trust
# registered-key auth — AuthorizedKeysCommand asks the control plane whether the
# presented key is registered to this workspace's owner (per-workspace agent
# token). Mirrors the golden image's auth (reuses its authorized-keys.sh). The
# login user is `workspace`; the workspace identifies itself by EDD_WORKSPACE_ID.
FROM debian:trixie-slim
RUN apt-get update \
  && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends openssh-server curl \
  && rm -rf /var/lib/apt/lists/* \
  && useradd --create-home --shell /bin/bash workspace \
  && usermod -p '*' workspace \
  && ssh-keygen -A \
  && mkdir -p /run/sshd
COPY services/ssh-gateway/sshd_config /etc/ssh/sshd_config
# Reuse the production golden-image AuthorizedKeysCommand (agent token).
COPY --chmod=0755 infra/images/base/authorized-keys.sh /usr/local/bin/edd-authorized-keys
COPY --chmod=0755 services/ssh-gateway/node-entrypoint.sh /usr/local/bin/node-entrypoint.sh
EXPOSE 22
ENTRYPOINT ["/usr/local/bin/node-entrypoint.sh"]
