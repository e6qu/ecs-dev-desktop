{
  "name": "@edd/reconciler",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/run.ts --bundle --platform=node --target=node22 --format=esm --log-level=warning '--banner:js=import { createRequire } from \"module\"; const require = createRequire(import.meta.url);' --outfile=dist/run.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integ": "vitest run --config vitest.integ.config.ts"
  },
  "dependencies": {
    "@edd/cloudwatch-metrics": "workspace:*",
    "@edd/compute-ecs": "workspace:*",
    "@edd/config": "workspace:*",
    "@edd/control-plane": "workspace:*",
    "@edd/core": "workspace:*",
    "@edd/db": "workspace:*",
    "@edd/iam-preflight": "workspace:*",
    "@edd/storage-ec2": "workspace:*"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudtrail": "^3.1087.0",
    "@aws-sdk/client-ecs": "^3.1087.0",
    "@aws-sdk/client-scheduler": "^3.1087.0",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "fast-check": "^4.9.0"
  }
}
